@model HomeViewModel
@{
    ViewData["Title"] = null;
    ViewData["GoogleAnalyticsId"] = Model.GoogleAnalyticsId;
}

@if (!string.IsNullOrEmpty(Model.AdSenseClient) && !Model.AdSenseClient.Contains("XXXXXXXXXX"))
{
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=@Model.AdSenseClient" crossorigin="anonymous"></script>
}

<section class="hero">
  <div class="wrap">
    <div>
      <span class="eyebrow mono">@Model.HeroEyebrow</span>
      <h1>@Html.Raw(Model.HeroTitle.Replace("\n", "<br>"))</h1>
      <p class="lead">@Model.HeroSubtitle</p>
      <div class="hero-ctas">
        <a href="#tendencias" class="btn btn-primary">Ver tendências</a>
        <a href="#ficha" class="btn btn-ghost">Conhecer o arquipélago</a>
      </div>
    </div>
    <div>
      <svg class="archipelago" viewBox="0 0 320 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mapa esquemático das dez ilhas de Cabo Verde">
        <path class="dotted" d="M40,40 L75,55 L70,85 L100,100 L150,150 L175,175 L190,205 L185,235 L155,255"/>
        <g>
          <circle cx="40" cy="40" r="5"></circle><text x="50" y="38">SANTO ANTÃO</text>
          <circle cx="75" cy="55" r="5"></circle><text x="85" y="58">S. VICENTE</text>
          <circle cx="70" cy="85" r="4"></circle><text x="46" y="100">S. NICOLAU</text>
          <circle cx="100" cy="100" r="4.5"></circle><text x="108" y="98">SAL</text>
          <circle cx="150" cy="150" r="4.5"></circle><text x="160" y="148">BOA VISTA</text>
          <circle cx="175" cy="175" r="4"></circle><text x="183" y="178">MAIO</text>
          <circle cx="190" cy="205" r="6"></circle><text x="200" y="208">SANTIAGO</text>
          <circle cx="185" cy="235" r="4.5"></circle><text x="193" y="238">FOGO</text>
          <circle cx="155" cy="255" r="4"></circle><text x="118" y="262">BRAVA</text>
        </g>
      </svg>
    </div>
  </div>
</section>

<main>
  <section class="section" id="tendencias">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow mono">NA BOCA DO MUNDO</span>
        <h2>@Model.TrendingTitle</h2>
        <p>Um resumo das histórias que mais têm levado pessoas a pesquisar por Cabo Verde nos últimos dias.</p>
      </div>

      @* Artigos em destaque — hero cards *@
@if (Model.FeaturedArticles.Any())
{
    <div class="trend-grid" style="margin-bottom:32px;">
        @foreach (var article in Model.FeaturedArticles)
        {
            await Html.RenderPartialAsync("_ArticleCard", article);
        }
    </div>
    <hr style="border:none;border-top:1px solid var(--espuma-2);margin:32px 0;">
}

@* Todos os artigos com paginação *@
  @if (Model.AllArticles.Any())
  {
      <div class="trend-grid">
          @foreach (var article in Model.AllArticles)
          {
              await Html.RenderPartialAsync("_ArticleCard", article);
          }
      </div>

      @* Paginação *@
      @if (Model.TotalPages > 1)
      {
          <div style="display:flex;justify-content:center;gap:10px;margin-top:36px;">
              @if (Model.CurrentPage > 1)
              {
                  <a href="/?page=@(Model.CurrentPage - 1)" class="btn btn-ghost" style="color:var(--azul-atlantico);border-color:var(--azul-atlantico);">← Anterior</a>
              }
              <span style="font-family:'IBM Plex Mono',monospace;font-size:0.82rem;padding:13px 0;color:#888;">
                  Página @Model.CurrentPage de @Model.TotalPages
              </span>
              @if (Model.CurrentPage < Model.TotalPages)
              {
                  <a href="/?page=@(Model.CurrentPage + 1)" class="btn btn-primary">Seguinte →</a>
              }
          </div>
      }
  }
      else
      {
          <p style="color:#888;padding:24px 0;">Nenhum artigo em destaque de momento. <a href="/admin">Adicionar conteúdo →</a></p>
      }

      <div style="margin:48px 0;">
          @await Html.PartialAsync("_AdSlot", (Model.AdSenseClient, Model.AdSenseSlot1))
      </div>
    </div>
  </section>

  <section class="section ficha-section" id="ficha">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow mono">ARQUIPÉLAGO EM NÚMEROS</span>
        <h2>Ficha de Cabo Verde</h2>
      </div>
      <dl class="ficha">
        <div><dt>Capital</dt><dd>Praia, na ilha de Santiago</dd></div>
        <div><dt>Ilhas</dt><dd>10 ilhas vulcânicas, 9 habitadas, divididas em Barlavento e Sotavento</dd></div>
        <div><dt>População</dt><dd>Cerca de 590 mil habitantes no território, e mais de meio milhão na diáspora</dd></div>
        <div><dt>Línguas</dt><dd>Português (oficial) e Crioulo cabo-verdiano</dd></div>
        <div><dt>Moeda</dt><dd>Escudo cabo-verdiano (CVE)</dd></div>
        <div><dt>Independência</dt><dd>5 de julho de 1975, de Portugal</dd></div>
      </dl>
    </div>
  </section>

  <section class="section" id="cultura">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow mono">SONS, SABORES E TRADIÇÃO</span>
        <h2>Por dentro da Morabeza</h2>
        <p>Morabeza é a palavra cabo-verdiana para a hospitalidade calorosa que define o povo das ilhas.</p>
      </div>
      <div class="cultura-grid">
        @foreach (var item in Model.CultureItems)
        {
            <div class="cult-item">
                <svg class="icon" viewBox="0 0 48 48" aria-hidden="true">
                    @if (item.IconKey == "music")
                    {
                        <circle cx="24" cy="24" r="20" fill="none" stroke="#2E7DB8" stroke-width="2.5"/>
                        <path d="M14 28c3-8 17-8 20 0" stroke="#2E7DB8" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                        <circle cx="18" cy="19" r="2" fill="#2E7DB8"/>
                        <circle cx="30" cy="19" r="2" fill="#2E7DB8"/>
                    }
                    else if (item.IconKey == "food")
                    {
                        <path d="M10 30c0-8 6-14 14-14s14 6 14 14" fill="none" stroke="#C8392B" stroke-width="2.5"/>
                        <line x1="8" y1="30" x2="40" y2="30" stroke="#C8392B" stroke-width="2.5"/>
                    }
                    else if (item.IconKey == "festival")
                    {
                        <rect x="14" y="10" width="20" height="28" rx="3" fill="none" stroke="#3F7A56" stroke-width="2.5"/>
                        <line x1="14" y1="18" x2="34" y2="18" stroke="#3F7A56" stroke-width="2.5"/>
                        <line x1="14" y1="26" x2="34" y2="26" stroke="#3F7A56" stroke-width="2.5"/>
                    }
                    else
                    {
                        <path d="M6 34c8-18 28-18 36 0" fill="none" stroke="#F2B705" stroke-width="2.5"/>
                        <circle cx="24" cy="16" r="5" fill="none" stroke="#F2B705" stroke-width="2.5"/>
                    }
                </svg>
                <h3>@item.Title</h3>
                <p>@item.Description</p>
            </div>
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="newsletter">
        <div>
          <h3>Receba as tendências de Cabo Verde por email</h3>
          <p style="margin:6px 0 0;color:#C9D8DF;">Um resumo semanal, sem ruído.</p>
        </div>
        <form id="newsletter-form">
          @Html.AntiForgeryToken()
          <label for="email" style="display:none;">Email</label>
          <input id="newsletter-email" type="email" placeholder="o.seu@email.com" required>
          <button type="submit">Subscrever</button>
        </form>
      </div>
      <p id="newsletter-msg" style="display:none;margin-top:12px;text-align:center;font-size:0.9rem;"></p>

      <div style="margin-top:48px;">
          @await Html.PartialAsync("_AdSlot", (Model.AdSenseClient, Model.AdSenseSlot2))
      </div>
    </div>
  </section>
</main>

@section Scripts {
<script>
document.getElementById('newsletter-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const email = document.getElementById('newsletter-email').value;
    const res = await fetch('/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `email=${encodeURIComponent(email)}`
    });
    const data = await res.json();
    const msg = document.getElementById('newsletter-msg');
    msg.style.display = 'block';
    msg.style.color = data.success ? '#3F7A56' : '#C8392B';
    msg.textContent = data.message;
    if (data.success) this.reset();
});
</script>
}
