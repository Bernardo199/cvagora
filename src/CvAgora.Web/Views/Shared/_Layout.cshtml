<!DOCTYPE html>
<html lang="pt-PT">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@(ViewData["Title"] != null ? ViewData["Title"] + " — CV Agora" : "CV Agora — O que está a mexer no arquipélago")</title>
<meta name="description" content="@(ViewData["Description"] ?? "Tendências, notícias e cultura de Cabo Verde: Mundial 2026, política, economia e as Sete Maravilhas do arquipélago.")">
<meta property="og:title" content="@(ViewData["Title"] ?? "CV Agora")">
<meta property="og:description" content="@(ViewData["Description"] ?? "Tendências, notícias e cultura de Cabo Verde.")">
<meta property="og:type" content="website">
@if (ViewData["OgImage"] != null) {
<meta property="og:image" content="@ViewData["OgImage"]">
<meta name="google-adsense-account" content="ca-pub-6546463186349532">
}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;800;900&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true">

@if (!string.IsNullOrEmpty(ViewData["GoogleAnalyticsId"]?.ToString()))
{
    var gaId = ViewData["GoogleAnalyticsId"]!.ToString();
    <script async src="https://www.googletagmanager.com/gtag/js?id=@gaId"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '@gaId');
    </script>
}
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6546463186349532"
     crossorigin="anonymous"></script>
     <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-ER9CJ9BS6B"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-ER9CJ9BS6B');
</script>
</head>
<body>

<header>
  <div class="nav">
    <a href="/" class="logo">CV <span>·</span> AGORA</a>
    <ul>
      <li><a href="/#tendencias">Tendências</a></li>
      <li><a href="/#ficha">Arquipélago</a></li>
      <li><a href="/#cultura">Cultura</a></li>
      <li><a href="/pesquisa">Pesquisar</a></li>
    </ul>
    <button class="nav-toggle" aria-label="Menu" onclick="document.querySelector('.nav ul').classList.toggle('open')">☰</button>
  </div>
</header>
<div class="panu-stripe"></div>

@RenderBody()

<footer id="sobre">
  <div class="wrap">
    <div>
      <h4>CV Agora</h4>
      <p style="max-width:36ch;color:#C9D8DF;">Um espaço dedicado a contar, em português claro, o que está a mexer em Cabo Verde — do Mundial à política, da economia à cultura.</p>
    </div>
    <div>
      <h4>Navegar</h4>
      <ul>
        <li><a href="/#tendencias">Tendências</a></li>
        <li><a href="/#ficha">Arquipélago</a></li>
        <li><a href="/#cultura">Cultura</a></li>
        <li><a href="/pesquisa">Pesquisar</a></li>
      </ul>
    </div>
    <div>
      <h4>Legal</h4>
      <ul>
        <li><a href="/privacidade">Política de privacidade</a></li>
        <li><a href="/termos">Termos de utilização</a></li>
        <li><a href="/contacto">Contacto</a></li>
      </ul>
    </div>
  </div>
  <p class="fine">© @DateTime.Now.Year CV Agora. Conteúdo informativo e de carácter geral; verifique sempre as fontes oficiais para decisões importantes.</p>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
